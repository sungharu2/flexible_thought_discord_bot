{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs", // nodenextлЎң н•ҳлӢҲ лІ„к·ё л°ңмғқ
        "moduleResolution": "node", // nodenextлЎң н•ҳлӢҲ лІ„к·ё л°ңмғқ
        "esModuleInterop": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "strict": true,
        "noImplicitAny": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}